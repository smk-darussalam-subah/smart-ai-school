# =============================================================================
# .env.staging — Environment Variables untuk Stack Staging (N-20)
# Salin file ini ke .env.staging dan isi nilainya.
# JANGAN commit .env.staging ke git (sudah di .gitignore).
#
# CARA PAKAI:
#   cp .env.staging.example .env.staging
#   nano .env.staging   # isi semua placeholder
# =============================================================================

# ─── Compose ──────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=smk-staging

# ─── PostgreSQL (koneksi ke smk-postgres yang sama, DB berbeda) ───────────────
# POSTGRES_USER dan POSTGRES_PASSWORD harus SAMA dengan prod
# (staging connect ke container postgres yang sama).
POSTGRES_USER=smk_admin
POSTGRES_PASSWORD=<SAMA_SEPERTI_PROD>

# STAGING_DATABASE_URL: di-generate otomatis oleh deploy.yml dari POSTGRES_PASSWORD.
# Isi placeholder ini agar deploy.yml bisa update via sed.
# Format: postgresql://<user>:<encoded_pass>@postgres:5432/smk_staging_db
STAGING_DATABASE_URL=postgresql://smk_admin:<PLACEHOLDER>@postgres:5432/smk_staging_db

# ─── Redis (shared dengan prod) ───────────────────────────────────────────────
REDIS_PASSWORD=<SAMA_SEPERTI_PROD>
# REDIS_URL di-generate otomatis oleh deploy.yml
REDIS_URL=redis://:PLACEHOLDER@redis:6379

# ─── Keycloak (shared dengan prod) ────────────────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=<SAMA_SEPERTI_PROD>
KEYCLOAK_API_CLIENT_SECRET=<SAMA_SEPERTI_PROD>
KEYCLOAK_WEB_CLIENT_SECRET=<SAMA_SEPERTI_PROD>

# ─── Secrets App Staging ──────────────────────────────────────────────────────
# NEXTAUTH_SECRET harus berbeda dari prod untuk isolasi session
NEXTAUTH_SECRET=<BUAT_BARU_MIN_32_CHARS>

# ─── URL Staging ──────────────────────────────────────────────────────────────
STAGING_WEB_URL=https://staging.smkdarussalamsubah.sch.id
STAGING_API_URL=https://staging-api.smkdarussalamsubah.sch.id

# ─── Metabase (opsional — sama seperti prod atau kosong) ─────────────────────
METABASE_SITE_URL=
METABASE_SECRET_KEY=
METABASE_DASHBOARD_ID=

# ─── n8n ──────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=<SAMA_SEPERTI_PROD_ATAU_STAGING_KHUSUS>
N8N_ENCRYPTION_KEY=<SAMA_SEPERTI_PROD>

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<SAMA_SEPERTI_PROD>

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=<SAMA_SEPERTI_PROD>
MINIO_ROOT_PASSWORD=<SAMA_SEPERTI_PROD>

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<SAMA_SEPERTI_PROD_ATAU_KOSONG>

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=staging
SERVER_HOST=<IP_VPS_STAGING>
