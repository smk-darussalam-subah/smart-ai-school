// =============================================================================
// Prisma Schema — Smart AI School (SMK Darussalam Subah)
// Database: PostgreSQL 16 + pgvector
// Prinsip: UUID PK, timestamps di semua tabel, soft delete, schema terpisah
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "postgresqlExtensions"]
  // binaryTargets: "native" untuk dev (macOS/Windows/Linux glibc),
  // "linux-musl-openssl-3.0.x" untuk Docker Alpine (musl + OpenSSL 3.x).
  // Alpine 3.19+ pakai OpenSSL 3.x — binary default Prisma (linux-musl)
  // di-compile dengan OpenSSL 1.1.x sehingga crash di Alpine modern.
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, uuidOssp(map: "uuid-ossp"), pgTrgm(map: "pg_trgm")]
  schemas    = ["auth", "academic", "student", "teacher", "ppdb", "finance", "notification", "ai_knowledge", "audit", "school", "gamification"]
}

// =============================================================================
// AUTH SCHEMA
// =============================================================================

model User {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  keycloakId  String    @unique @map("keycloak_id") @db.Uuid
  email       String    @unique @db.VarChar(255)
  fullName    String    @map("full_name") @db.VarChar(255)
  phone       String?   @db.VarChar(20)
  gender      Gender?                              // L / P — atribut personal (dipakai juga utk siswa)
  birthDate   DateTime? @map("birth_date") @db.Date
  address     String?   @db.Text
  role        UserRole
  isActive    Boolean   @default(true) @map("is_active")
  avatarUrl   String?   @map("avatar_url")
  consentAt   DateTime? @map("consent_at") // R-05: timestamp saat operator konfirmasi persetujuan data
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at") // soft delete

  // Relations
  student     Student?
  teacher     Teacher?
  staff       Staff?                               // identitas kepegawaian (KS/Guru/TU) — 2J-4
  parent      Student[]  @relation("ParentStudent")
  leads       PpdbLead[] @relation("AssignedLeads")

  @@map("users")
  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@schema("auth")
}

enum UserRole {
  SUPER_ADMIN
  KEPALA_SEKOLAH
  TATA_USAHA    // Staf administrasi: keuangan, PPDB admin, data siswa
  GURU
  SISWA
  ORANG_TUA
  INDUSTRI      // Mitra industri: PKL/Prakerin, BKK, rekrutmen

  @@schema("auth")
}

enum Gender {
  L  // Laki-laki
  P  // Perempuan

  @@schema("auth")
}

// ── Permission-Based RBAC ────────────────────────────────────────────────────
// 7 role = dasar (Keycloak realm roles). Permission = granular aksi.
// Super Admin ubah izin role/user TANPA deploy.

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(100)  // 'student.create', 'spp.approve'
  description String   @db.VarChar(255)
  module      String   @db.VarChar(50)            // 'student', 'finance', 'academic'
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions      RolePermission[]
  userOverrides        UserPermissionOverride[]

  @@map("permissions")
  @@schema("auth")
}

model RolePermission {
  role         UserRole
  permissionId String     @map("permission_id") @db.Uuid

  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([role, permissionId])
  @@map("role_permissions")
  @@schema("auth")
}

model UserPermissionOverride {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String     @map("user_id") @db.Uuid  // FK ke auth.users
  permissionId String     @map("permission_id") @db.Uuid
  grant        Boolean                                 // true = beri, false = tarik
  createdAt    DateTime   @default(now()) @map("created_at")

  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
  @@map("user_permission_overrides")
  @@schema("auth")
}

// =============================================================================
// ACADEMIC SCHEMA
// =============================================================================

model Class {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String    @db.VarChar(50)   // mis: 'XII RPL 1'
  majorCode    String    @map("major_code") @db.VarChar(10) // RPL, TKRO, DKV, AKL
  grade        Int       // 10, 11, 12
  academicYear String    @map("academic_year") @db.VarChar(9) // '2025/2026'
  capacity     Int       @default(36)
  teacherId    String?   @map("teacher_id") @db.Uuid // wali kelas
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  students            Student[]
  teacher             Teacher?             @relation(fields: [teacherId], references: [id])
  teachingAssignments TeachingAssignment[]
  attendanceRecords   Attendance[]
  schedules           Schedule[]
  rpps                Rpp[]
  reportCards         ReportCard[]
  activities          ClassActivity[]
  lmsModules          LmsModule[]
  assessmentSessions   AssessmentSession[]

  @@unique([name, academicYear])
  @@map("classes")
  @@schema("academic")
}

// =============================================================================
// STUDENT SCHEMA
// =============================================================================

model Student {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String        @unique @map("user_id") @db.Uuid
  nis       String        @unique @db.VarChar(20) // Nomor Induk Siswa
  classId   String?       @map("class_id") @db.Uuid
  parentId  String?       @map("parent_id") @db.Uuid
  status    StudentStatus @default(active)
  joinedAt  DateTime      @map("joined_at") @db.Date
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  // Relations
  user        User         @relation(fields: [userId], references: [id])
  class       Class?       @relation(fields: [classId], references: [id])
  parent      User?        @relation("ParentStudent", fields: [parentId], references: [id])
  grades      Grade[]
  attendance  Attendance[]
  reportCards ReportCard[]
  sppPayments SppPayment[]
  lmsProgress LmsModuleProgress[]
  assessmentResponses AssessmentResponse[]
  studentBadges       StudentBadge[]
  studentXp           StudentXp?

  @@index([classId])   // StudentService.findAll(classId filter) + ownership SISWA/OT
  @@index([parentId])  // resolveChildStudentIds() — setiap request ORANG_TUA
  @@map("students")
  @@schema("student")
}

enum StudentStatus {
  active
  inactive
  graduated
  dropped

  @@schema("student")
}

// =============================================================================
// TEACHER SCHEMA
// =============================================================================

model Teacher {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @unique @map("user_id") @db.Uuid
  // Identitas kepegawaian (NIY) pindah ke school.Staff (2J-4). Teacher = hal mengajar saja.
  isWaliKelas Boolean   @default(false) @map("is_wali_kelas")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  user        User                 @relation(fields: [userId], references: [id])
  walikelas   Class[]
  assignments TeachingAssignment[]
  attendances TeacherAttendance[]
  rpps        Rpp[]
  activities  ClassActivity[]
  lmsModules         LmsModule[]
  assessmentSessions  AssessmentSession[]
  questions           Question[]
  questionSets        QuestionSet[]

  @@map("teachers")
  @@schema("teacher")
}


// Presensi Guru (referensi KamilEdu Modul 8) — check-in/out + GPS geofence.
// Foto selfie: photoUrl nullable (File Storage API = just-in-time, lihat decision-log).
// outsideGeofence: true bila (a) jarak > radius, atau (b) sekolah ber-geofence
// tapi koordinat tidak dikirim (tak dapat diverifikasi).
model TeacherAttendance {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId       String    @map("teacher_id") @db.Uuid
  date            DateTime  @db.Date
  checkInAt       DateTime  @map("check_in_at")
  checkOutAt      DateTime? @map("check_out_at")
  latIn           Decimal?  @map("lat_in") @db.Decimal(9, 6)
  lngIn           Decimal?  @map("lng_in") @db.Decimal(9, 6)
  latOut          Decimal?  @map("lat_out") @db.Decimal(9, 6)
  lngOut          Decimal?  @map("lng_out") @db.Decimal(9, 6)
  distanceInM     Int?      @map("distance_in_m")
  outsideGeofence Boolean   @default(false) @map("outside_geofence")
  photoUrl        String?   @map("photo_url") @db.Text
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, date])
  @@index([date])
  @@map("teacher_attendance")
  @@schema("teacher")
}

// =============================================================================
// PPDB SCHEMA
// =============================================================================

model PpdbLead {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName       String     @map("full_name") @db.VarChar(255)
  phone          String     @db.VarChar(20)
  schoolOrigin   String?    @map("school_origin") @db.VarChar(255)
  interestMajor  String?    @map("interest_major") @db.VarChar(100)
  source         LeadSource @default(other)
  status         LeadStatus @default(new)
  notes          String?    @db.Text
  assignedTo     String?    @map("assigned_to") @db.Uuid
  followUpAt     DateTime?  @map("follow_up_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  // Relations
  assignedUser  User? @relation("AssignedLeads", fields: [assignedTo], references: [id])

  @@index([status, createdAt])
  @@index([phone])
  @@index([assignedTo])
  @@map("leads")
  @@schema("ppdb")
}

enum LeadStatus {
  new
  contacted
  interested
  registered
  paid
  accepted
  rejected
  cold

  @@schema("ppdb")
}

enum LeadSource {
  chatbot_wa
  website
  referral
  instagram
  tiktok
  event
  walk_in
  other

  @@schema("ppdb")
}

// =============================================================================
// ACADEMIC SCHEMA — Model baru T-12 (boundary: academic = operasional)
// teacher schema = identitas SDM; academic schema = mengajar + nilai + absensi
// =============================================================================

model TeachingAssignment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId    String   @map("teacher_id") @db.Uuid  // ref ke teacher.teachers
  classId      String   @map("class_id") @db.Uuid
  subject      String   @db.VarChar(100)              // Matematika, B.Indonesia, dll
  hoursPerWeek Int      @default(2) @map("hours_per_week")
  academicYear String   @map("academic_year") @db.VarChar(9)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  teacher   Teacher    @relation(fields: [teacherId], references: [id])
  class     Class      @relation(fields: [classId], references: [id])
  grades    Grade[]
  schedules Schedule[]

  @@unique([teacherId, classId, subject, academicYear])
  @@index([classId])  // TeachingAssignmentService.findAll(classId-only, elevated) — unik composite mulai dari teacherId, tidak cover classId standalone
  @@map("teaching_assignments")
  @@schema("academic")
}

model Grade {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId    String    @map("student_id") @db.Uuid
  assignmentId String    @map("assignment_id") @db.Uuid  // ref TeachingAssignment
  semester     Int                                        // 1 atau 2
  academicYear String    @map("academic_year") @db.VarChar(9)
  score        Decimal   @db.Decimal(5, 2)
  type         GradeType
  notes        String?   @db.Text
  submittedBy  String    @map("submitted_by") @db.Uuid   // userId pelaku (auth.users, audit — no FK; jika perlu teacher, trace via user→teacher)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  student    Student            @relation(fields: [studentId], references: [id])
  assignment TeachingAssignment @relation(fields: [assignmentId], references: [id])

  @@index([studentId, academicYear, semester])
  @@index([assignmentId])
  @@index([submittedBy])
  @@map("grades")
  @@schema("academic")
}

enum GradeType {
  uts
  uh
  uas
  praktik
  sikap

  @@schema("academic")
}

model Attendance {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId  String           @map("student_id") @db.Uuid
  classId    String           @map("class_id") @db.Uuid
  date       DateTime         @db.Date
  status     AttendanceStatus
  notes      String?          @db.Text
  recordedBy String           @map("recorded_by") @db.Uuid  // userId pelaku (auth.users, audit — no FK; jika perlu teacher, trace via user→teacher)
  createdAt  DateTime         @default(now()) @map("created_at")

  // Relations
  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, date])
  @@index([classId, date])
  @@map("attendance")
  @@schema("academic")
}

enum AttendanceStatus {
  hadir
  izin
  sakit
  alpha

  @@schema("academic")
}

// =============================================================================
// ACADEMIC SCHEMA — Schedule (SMA-39)
//
// Schedule = TEMPLATE jadwal mingguan rekuren (bukan sesi konkret).
// Konsep JP (jam pelajaran) sengaja dipakai, BUKAN jam dinding (clock-time).
// Pemetaan JP → jam dinding adalah konfigurasi sekolah (bel), bukan urusan tabel ini.
// dayOfWeek disimpan mentah (1–6); libur/kalender akademik diatur oleh konsumen.
//
// Forward-compat Tahap 2 (KBM):
//   TimetableEntry akan di-generate dari Schedule (+ penambahan field Room FK opsional).
//   ClassSession harian di-generate dari TimetableEntry.
//   Attendance siswa akan diberi kolom sessionId? (nullable, additive migration).
//   Jangan reserve nama tabel: sessions, rooms, timetable_entries, substitutions,
//   session_event_logs → sudah dicadangkan untuk modul KBM Tahap 2.
// =============================================================================

model Schedule {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classId              String   @map("class_id") @db.Uuid
  teachingAssignmentId String   @map("teaching_assignment_id") @db.Uuid
  dayOfWeek            Int      @map("day_of_week")  // 1=Senin .. 6=Sabtu
  jpStart              Int      @map("jp_start")     // jam pelajaran ke-N mulai
  jpEnd                Int      @map("jp_end")       // jam pelajaran ke-N selesai (inklusif)
  room                 String?  @db.VarChar(50)      // nullable — sekolah kecil mungkin belum pakai
  academicYear         String   @map("academic_year") @db.VarChar(9)
  semester             Int
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  class              Class              @relation(fields: [classId], references: [id])
  teachingAssignment TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id])

  // Satu kelas tidak bisa punya dua jadwal di slot JP yang sama.
  // + 2G-2: exclusion constraint "schedules_class_jp_range_excl" (raw SQL,
  //   migration 20260611000004) menolak OVERLAP RENTANG di level DB —
  //   Prisma tidak bisa mengekspresikan EXCLUDE, jangan di-drop saat db pull.
  @@unique([classId, dayOfWeek, jpStart, academicYear, semester])
  @@index([teachingAssignmentId])
  @@map("schedules")
  @@schema("academic")
}


// RPP — Rencana Pelaksanaan Pembelajaran (referensi KamilEdu Modul 11)
// Pipeline: draft → submitted → approved | revision (revisi → edit → submitted lagi).
// fileUrl nullable (File Storage API just-in-time); content = isi RPP teks/markdown.
// reviewerId/actor = Keycloak sub (pola AuditLog — tanpa FK lintas-schema).
model Rpp {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId    String    @map("teacher_id") @db.Uuid
  classId      String?   @map("class_id") @db.Uuid
  subject      String    @db.VarChar(100)
  title        String    @db.VarChar(255)
  content      String?   @db.Text   // ringkasan/preview teks
  body         Json?     @db.JsonB  // Modul Ajar terstruktur (Kurikulum Merdeka): CP/TP/ATP/profil/sarana/kegiatan/asesmen/dst
  fileUrl      String?   @map("file_url") @db.Text
  status       RppStatus @default(draft)
  reviewerId   String?   @map("reviewer_id") @db.VarChar(64)
  reviewerName String?   @map("reviewer_name") @db.VarChar(100)
  reviewNote   String?   @map("review_note") @db.Text
  submittedAt  DateTime? @map("submitted_at")
  reviewedAt   DateTime? @map("reviewed_at")
  academicYear String    @map("academic_year") @db.VarChar(9)
  semester     Int
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  teacher    Teacher     @relation(fields: [teacherId], references: [id])
  class      Class?      @relation(fields: [classId], references: [id])
  lmsModules LmsModule[]

  @@index([status, submittedAt])
  @@index([teacherId, academicYear, semester])
  @@map("rpp")
  @@schema("academic")
}

enum RppStatus {
  draft
  submitted
  approved
  revision

  @@schema("academic")
}

// =============================================================================
// LMS (Learning Management) — modul belajar + progres siswa (2P-1).
// Modul = materi terstruktur per mapel, opsional terkait Rpp sumber. Guru kelola
// modul miliknya + publish; siswa baca modul published kelasnya + lapor progres.
// Additive — tak mengubah tabel lain. Kuis/diagnostik = modul berikutnya.
// =============================================================================
model LmsModule {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId    String          @map("teacher_id") @db.Uuid
  rppId        String?         @map("rpp_id") @db.Uuid   // Modul Ajar sumber bila diaktifkan dari RPP
  classId      String?         @map("class_id") @db.Uuid // target kelas (opsional)
  subject      String          @db.VarChar(100)
  title        String          @db.VarChar(255)
  tp           String?         @db.VarChar(50)            // Tujuan Pembelajaran, mis. 'TP 2.1'
  jpAllocation Int?            @map("jp_allocation")
  kktp         Int             @default(75)
  content      String?         @db.Text                   // materi (markdown)
  orderIndex   Int             @default(0) @map("order_index")
  status       LmsModuleStatus @default(draft)
  academicYear String          @map("academic_year") @db.VarChar(9)
  semester     Int
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @default(now()) @updatedAt @map("updated_at")

  teacher  Teacher             @relation(fields: [teacherId], references: [id])
  rpp      Rpp?                @relation(fields: [rppId], references: [id])
  class    Class?              @relation(fields: [classId], references: [id])
  progress LmsModuleProgress[]
  sessions  AssessmentSession[]

  @@index([teacherId, subject])
  @@index([classId, status])
  @@map("lms_modules")
  @@schema("academic")
}

model LmsModuleProgress {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId    String            @map("module_id") @db.Uuid
  studentId   String            @map("student_id") @db.Uuid
  progress    Int               @default(0) // 0–100
  status      LmsProgressStatus @default(active)
  startedAt   DateTime?         @map("started_at")
  completedAt DateTime?         @map("completed_at")
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at")

  module  LmsModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  student Student   @relation(fields: [studentId], references: [id])

  @@unique([moduleId, studentId])
  @@index([studentId])
  @@map("lms_module_progress")
  @@schema("academic")
}

enum LmsModuleStatus {
  draft
  published
  archived

  @@schema("academic")
}

enum LmsProgressStatus {
  locked
  active
  completed

  @@schema("academic")
}

// =============================================================================
// Assessment Sessions — sesi asesmen (diagnostik/formatif/sumatif) terkait LMS.
// Guru membuat sesi dari modul LMS, siswa mengerjakan, sistem menilai otomatis.
// =============================================================================
model AssessmentSession {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId     String                @map("module_id") @db.Uuid
  teacherId    String                @map("teacher_id") @db.Uuid
  classId      String?               @map("class_id") @db.Uuid
  title        String                @db.VarChar(255)
  type         AssessmentType
  status       AssessmentSessionStatus @default(draft)
  questions    Json                  @db.JsonB
  durationMinutes Int?               @map("duration_minutes") // U2: timer durasi pengerjaan (menit)
  randomizeOrder Boolean   @default(false) @map("randomize_order") // U2: randomisasi urutan soal
  startedAt    DateTime?             @map("started_at")
  completedAt  DateTime?             @map("completed_at")
  academicYear String                @map("academic_year") @db.VarChar(9)
  semester     Int
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @default(now()) @updatedAt @map("updated_at")

  module     LmsModule           @relation(fields: [moduleId], references: [id])
  teacher    Teacher             @relation(fields: [teacherId], references: [id])
  class      Class?              @relation(fields: [classId], references: [id])
  responses  AssessmentResponse[]

  @@index([moduleId, status])
  @@index([teacherId, academicYear, semester])
  @@index([classId, status])
  @@map("assessment_sessions")
  @@schema("academic")
}

model AssessmentResponse {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId   String    @map("session_id") @db.Uuid
  studentId   String    @map("student_id") @db.Uuid
  answers     Json?     @db.JsonB
  score       Int?
  startedAt   DateTime? @map("started_at") // U2: kapan siswa mulai mengerjakan
  timeSpentSec Int?     @map("time_spent_sec") // U2: total detik yang dihabiskan
  submittedAt DateTime? @map("submitted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  session  AssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student  Student           @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@map("assessment_responses")
  @@schema("academic")
}

enum AssessmentType {
  diagnostik
  formatif
  sumatif

  @@schema("academic")
}

enum AssessmentSessionStatus {
  draft
  active
  completed

  @@schema("academic")
}


// Rapor (KamilEdu M12) — snapshot nilai+kehadiran per siswa per semester.
// Pipeline: draft → checked (diperiksa) → published (terbit) → distributed (dibagikan);
// return: checked → draft. grades/attendance = SNAPSHOT JSON (immutable saat terbit).
model ReportCard {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId     String       @map("student_id") @db.Uuid
  classId       String       @map("class_id") @db.Uuid
  academicYear  String       @map("academic_year") @db.VarChar(9)
  semester      Int
  status        ReportStatus @default(draft)
  grades        Json         // SubjectSnapshot[]: {subject,count,average,byType}
  attendance    Json?        // {hadir,izin,sakit,alpha}
  notes         String?      @db.Text
  generatedAt   DateTime     @default(now()) @map("generated_at")
  checkedAt     DateTime?    @map("checked_at")
  publishedAt   DateTime?    @map("published_at")
  distributedAt DateTime?    @map("distributed_at")
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, academicYear, semester])
  @@index([classId, academicYear, semester])
  @@index([status])
  @@map("report_cards")
  @@schema("academic")
}

enum ReportStatus {
  draft
  checked
  published
  distributed

  @@schema("academic")
}

// Kegiatan Kelas (KamilEdu M9) — jurnal kegiatan per kelas oleh guru.
model ClassActivity {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classId     String           @map("class_id") @db.Uuid
  teacherId   String           @map("teacher_id") @db.Uuid
  date        DateTime         @db.Date
  title       String           @db.VarChar(255)
  description String?          @db.Text
  category    ActivityCategory @default(pembelajaran)
  photoUrl    String?          @map("photo_url") @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at")

  class   Class   @relation(fields: [classId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@index([classId, date])
  @@index([teacherId])
  @@map("class_activities")
  @@schema("academic")
}

enum ActivityCategory {
  pembelajaran
  ulangan
  praktikum
  kegiatan
  lainnya

  @@schema("academic")
}

// DEV-03 — Tabel referensi mapel (2K-4, 2026-06-13).
// Additive: tidak ubah kolom subject String di teaching_assignments.
// code = singkatan unik (MTK, BIN, dll); name = nama lengkap.
// Soft-disable via isActive; tanpa DELETE di API.
model Subject {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("subjects")
  @@schema("academic")
}

// T3-02 (B5): KKTP config per-subject per-academic-year per-semester.
// KS/Wakakur sets custom KKTP threshold per mapel. Default 75 bila tidak ada entry.
model KktpConfig {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject      String   @db.VarChar(100)                         // "Matematika", "Pemrograman Web", dll (denormalized for flexibility)
  kktp         Int                                               // 0-100, default 75
  academicYear String   @map("academic_year") @db.VarChar(9)    // "2025/2026"
  semester     Int                                               // 1 or 2
  createdBy    String?  @map("created_by") @db.Uuid             // userId (audit)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([subject, academicYear, semester])
  @@map("kktp_configs")
  @@schema("academic")
}

// =============================================================================
// FINANCE SCHEMA — minimal model (N-1)
// =============================================================================

model SppPayment {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId  String        @map("student_id") @db.Uuid
  month      Int                                    // 1-12
  year       Int
  amount     Decimal       @db.Decimal(12, 2)
  status     PaymentStatus @default(unpaid)
  paidAt     DateTime?     @map("paid_at")
  receiptNo  String?       @unique @map("receipt_no") @db.VarChar(50)
  recordedBy String?       @map("recorded_by") @db.Uuid  // userId pelaku (auth.users, audit — no FK)
  approvedBy String?       @map("approved_by") @db.Uuid  // userId SA/KS yang approve (auth.users, audit — no FK)
  approvedAt DateTime?     @map("approved_at")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  // Relations
  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, month, year])
  @@index([status, year, month])
  @@map("spp_payments")
  @@schema("finance")
}

enum PaymentStatus {
  unpaid
  paid
  late
  waived

  @@schema("finance")
}

// =============================================================================
// NOTIFICATION SCHEMA — minimal model (N-1)
// =============================================================================

model NotificationLog {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipient String       @db.VarChar(100)   // nomor WA atau email
  channel   NotifChannel
  subject   String?      @db.VarChar(255)
  body      String       @db.Text
  status    NotifStatus  @default(pending)
  sentAt    DateTime?    @map("sent_at")
  error     String?      @db.Text
  refType   String?      @map("ref_type")   // "grade", "payment", "ppdb"
  refId     String?      @map("ref_id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([recipient, createdAt])
  @@index([status])
  @@index([refType, refId, recipient, channel, status])
  @@map("notification_logs")
  @@schema("notification")
}

enum NotifChannel {
  whatsapp
  email
  push

  @@schema("notification")
}

enum NotifStatus {
  pending
  sent
  failed

  @@schema("notification")
}


// Pengumuman Sekolah (referensi KamilEdu Modul 14)
// createdBy = Keycloak sub, TANPA FK lintas-schema (pola ChatSession.userId)
model Announcement {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String               @db.VarChar(255)
  content       String               @db.Text
  category      AnnouncementCategory @default(umum)
  priority      AnnouncementPriority @default(biasa)
  audience      Json                 @default("[\"ALL\"]")  // array role atau ["ALL"]
  isPinned      Boolean              @default(false) @map("is_pinned")
  status        AnnouncementStatus   @default(draft)
  publishedAt   DateTime?            @map("published_at")
  scheduledAt   DateTime?            @map("scheduled_at")
  createdBy     String?              @map("created_by") @db.VarChar(64)
  createdByName String?              @map("created_by_name") @db.VarChar(100)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @default(now()) @updatedAt @map("updated_at")

  @@index([status, isPinned, publishedAt(sort: Desc)])
  @@index([category, status])
  @@map("announcements")
  @@schema("notification")
}

enum AnnouncementCategory {
  umum
  akademik
  keuangan
  kegiatan
  darurat

  @@schema("notification")
}

enum AnnouncementPriority {
  biasa
  penting
  urgent

  @@schema("notification")
}

enum AnnouncementStatus {
  draft
  published
  archived

  @@schema("notification")
}

// =============================================================================
// AI KNOWLEDGE SCHEMA — N-2: konsolidasi KnowledgeDocument + AiDocument
// Diganti dengan satu model RagChunk
// Embedding model: nomic-embed-text via Ollama → 768 dimensi
// ⚠️ vector(768) HARUS konsisten dengan OLLAMA_EMBED_DIMENSIONS=768 di .env
// =============================================================================

model RagChunk {
  id          String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String                      @db.VarChar(500)
  content     String                      @db.Text                // teks asli untuk display
  embedding   Unsupported("vector(768)")? // nomic-embed-text = 768d
  source      String                      @db.VarChar(255)        // nama file / URL asal
  category    String                      @db.VarChar(100)        // faq, peraturan, jadwal, dll
  metadata    Json?                                               // page number, section, dll
  isActive    Boolean                     @default(false) @map("is_active") // false = draft
  createdBy   String?                     @map("created_by")   @db.Uuid    // audit: auth.users.id
  publishedBy String?                     @map("published_by") @db.Uuid    // audit: auth.users.id
  publishedAt DateTime?                   @map("published_at")
  createdAt   DateTime                    @default(now()) @map("created_at")
  updatedAt   DateTime                    @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@map("rag_chunks")
  @@schema("ai_knowledge")
}


// =============================================================================
// AI KNOWLEDGE SCHEMA — Chat history (SMA-49)
// ChatSession: satu percakapan per user (additive — tidak menyentuh tabel lain)
// ChatMessage: pesan individual dalam satu session
// =============================================================================

enum MessageRole {
  user
  assistant

  @@schema("ai_knowledge")
}

model ChatSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  title     String?   @db.VarChar(100)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  messages  ChatMessage[]

  @@index([userId])
  @@index([updatedAt])
  @@map("chat_sessions")
  @@schema("ai_knowledge")
}

model ChatMessage {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  role      MessageRole
  content   String      @db.Text
  createdAt DateTime    @default(now()) @map("created_at")

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
  @@schema("ai_knowledge")
}

// =============================================================================
// SCHOOL CONFIG SCHEMA — 2B-3
// Konfigurasi sekolah: profil, jurusan, tahun ajaran, semester, kalender.
// ADDITIVE only — tidak menyentuh tabel existing.
// =============================================================================

model SchoolProfile {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String   @db.VarChar(255)       // SMK Darussalam Subah
  npsn           String?  @db.VarChar(20)        // Nomor Pokok Sekolah Nasional
  address        String?  @db.Text
  phone          String?  @db.VarChar(20)
  email          String?  @db.VarChar(100)
  website        String?  @db.VarChar(255)
  headmasterName String?  @map("headmaster_name") @db.VarChar(255)
  headmasterNip  String?  @map("headmaster_nip") @db.VarChar(30)
  logoUrl        String?  @map("logo_url")
  accreditation  String?  @db.VarChar(5)          // A, B, C
  kioskToken     String?  @unique @map("kiosk_token") @db.VarChar(64) // token link publik Ruang Guru (rotatable)
  // 2F-2: geofence presensi guru (null = geofence nonaktif)
  latitude        Decimal? @db.Decimal(9, 6)
  longitude       Decimal? @db.Decimal(9, 6)
  geofenceRadiusM Int      @default(300) @map("geofence_radius_m")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("school_profile")
  @@schema("school")
}

model Major {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique @db.VarChar(10)    // TKRO, TBSM, AKL, TJKT
  name        String   @db.VarChar(100)           // Teknik Kendaraan Ringan Otomotif
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  staffPositions StaffPosition[]

  @@map("majors")
  @@schema("school")
}

model AcademicYear {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique @db.VarChar(9)       // 2025/2026, 2026/2027
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  semesters       Semester[]
  calendarEvents  AcademicCalendar[]
  staffPositions  StaffPosition[]

  @@map("academic_years")
  @@schema("school")
}

model Semester {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  academicYearId String       @map("academic_year_id") @db.Uuid
  number         Int                                  // 1 atau 2
  startDate      DateTime     @map("start_date") @db.Date
  endDate        DateTime     @map("end_date") @db.Date
  isActive       Boolean      @default(false) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([academicYearId, number])
  @@map("semesters")
  @@schema("school")
}

model AcademicCalendar {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  academicYearId String       @map("academic_year_id") @db.Uuid
  name           String       @db.VarChar(255)         // UTS, UAS, Libur Idul Fitri
  startDate      DateTime     @map("start_date") @db.Date
  endDate        DateTime     @map("end_date") @db.Date
  type           CalendarType                          // holiday, exam, event, break
  description    String?      @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@index([academicYearId])
  @@index([type])
  @@index([startDate, endDate])
  @@map("academic_calendar")
  @@schema("school")
}

enum CalendarType {
  holiday
  exam
  event
  break

  @@schema("school")
}

// =============================================================================
// SCHOOL SCHEMA — Staff / Kepegawaian (2J-4)
//
// Identitas kepegawaian untuk SEMUA pegawai internal (KS / Guru / TU), 1:1 dgn
// auth.users. NIY = Nomor Induk Yayasan (yayasan swasta; tanpa aturan digit khusus).
// Guru = punya baris Staff (identitas) + Teacher (mengajar). TU/KS = Staff saja.
// Jabatan struktural/fungsional (Wakasek/Kaprog/BK/Bendahara/dll) = sprint 2J-5
// (school.position + staff_position), BUKAN di sini.
// =============================================================================
model Staff {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String           @unique @map("user_id") @db.Uuid
  niy              String?          @unique @db.VarChar(50) // Nomor Induk Yayasan — unik bila terisi
  employmentStatus EmploymentStatus @map("employment_status")
  joinedAt         DateTime?        @map("joined_at") @db.Date
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  user      User            @relation(fields: [userId], references: [id])
  positions StaffPosition[]

  @@index([deletedAt])
  @@map("staff")
  @@schema("school")
}

enum EmploymentStatus {
  GTY // Guru Tetap Yayasan
  GTT // Guru Tidak Tetap
  PTY // Pegawai Tetap Yayasan (tendik)
  PTT // Pegawai Tidak Tetap (tendik)

  @@schema("school")
}

// =============================================================================
// SCHOOL SCHEMA — Struktur Organisasi / Jabatan (2J-5)
//
// Jabatan struktural/fungsional/tendik TERPISAH dari role RBAC (7 role tetap).
// Position = katalog jabatan (hierarki via parentId). StaffPosition = penugasan
// pegawai ke jabatan, TERIKAT tahun ajaran (rotasi). PositionPermission = izin
// yang otomatis diberikan (UserPermissionOverride) selama penugasan aktif.
// Wali kelas TETAP di academic.Class.teacherId (tidak diduplikasi di sini).
// =============================================================================
enum PositionCategory {
  STRUKTURAL // KS, Wakasek, Kepala TU
  FUNGSIONAL // Koor BKK/Hubin, Guru BK, Kaprog, dll
  TENDIK     // Bendahara, Kepegawaian, Dapodik, dll

  @@schema("school")
}

enum PositionScopeType {
  NONE  // jabatan tunggal sekolah
  MAJOR // terikat jurusan (mis. Kaprog per TKRO/TBSM/TJKT/AKL)

  @@schema("school")
}

model Position {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String            @unique @db.VarChar(50) // WAKA_KURIKULUM, KAPROG, KOOR_BKK, ...
  name      String            @db.VarChar(100)
  category  PositionCategory
  parentId  String?           @map("parent_id") @db.Uuid // hierarki (BKK di bawah Humas)
  scopeType PositionScopeType @default(NONE) @map("scope_type")
  isActive  Boolean           @default(true) @map("is_active")
  sortOrder Int               @default(0) @map("sort_order")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  parent      Position?            @relation("PositionHierarchy", fields: [parentId], references: [id])
  children    Position[]           @relation("PositionHierarchy")
  permissions PositionPermission[]
  assignments StaffPosition[]

  @@index([parentId])
  @@map("positions")
  @@schema("school")
}

// Izin yang menempel pada jabatan. permissionId → auth.permissions (lintas-schema,
// tanpa FK — pola sama seperti audit field). Diterapkan sebagai UserPermissionOverride
// saat penugasan aktif, dicabut saat penugasan berakhir.
model PositionPermission {
  positionId   String @map("position_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@id([positionId, permissionId])
  @@map("position_permissions")
  @@schema("school")
}

model StaffPosition {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  staffId        String    @map("staff_id") @db.Uuid
  positionId     String    @map("position_id") @db.Uuid
  academicYearId String    @map("academic_year_id") @db.Uuid
  majorId        String?   @map("major_id") @db.Uuid // wajib bila position.scopeType=MAJOR
  isActive       Boolean   @default(true) @map("is_active")
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  staff        Staff        @relation(fields: [staffId], references: [id])
  position     Position     @relation(fields: [positionId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  major        Major?       @relation(fields: [majorId], references: [id])

  // Satu pegawai tak boleh dobel di jabatan+jurusan+tahun yang sama.
  @@unique([staffId, positionId, academicYearId, majorId])
  @@index([positionId, academicYearId])
  @@index([academicYearId])
  @@map("staff_positions")
  @@schema("school")
}

// =============================================================================
// AUDIT SCHEMA — 2B-1: AuditLog persisten
// Prasyarat UU PDP + gerbang go-live data nyata.
// PII-minimal: actorId=keycloakId, username, roles (denormalisasi forensik).
// Tidak menyimpan kredensial, body sensitif, atau nilai PII mentah.
// =============================================================================

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  createdAt    DateTime @default(now()) @map("created_at")
  actorId      String?  @map("actor_id")       // Keycloak sub; null = sistem/anonim
  actorUsername String? @map("actor_username")
  actorRoles   String[] @map("actor_roles")     // denormalisasi — tetap terbaca walau user dihapus
  action       String                            // mis. "student.create", "spp.approve"
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  method       String
  path         String
  statusCode   Int      @map("status_code")
  outcome      String                            // "success" | "failure"
  ip           String?
  userAgent    String?  @map("user_agent")
  metadata     Json?                             // PII-minimal: field names + non-sensitive values

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_log")
  @@schema("audit")
}

// =============================================================================
// ACADEMIC SCHEMA — Question Bank (P14 W3-2)
// Repository soal yang reusable untuk assessment sessions.
// Guru dapat membuat, menyimpan, dan menggunakan kembali soal.
// =============================================================================

enum QuestionType {
  multiple_choice
  essay
  true_false
  matching

  @@schema("academic")
}

enum QuestionDifficulty {
  easy
  medium
  hard

  @@schema("academic")
}

model Question {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId  String             @map("teacher_id") @db.Uuid
  subject    String             @db.VarChar(100)
  type       QuestionType
  body       String             @db.Text
  options    Json?              @db.JsonB
  answer     String?            @db.Text
  difficulty QuestionDifficulty @default(medium)
  tags       String[]
  rubric     Json?              @db.JsonB // U2: essay rubrik — Array<{ id, name, weight, maxScore, description }>
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  teacher      Teacher       @relation(fields: [teacherId], references: [id])
  questionSets QuestionSet[]

  @@index([teacherId, subject])
  @@index([subject, type])
  @@map("questions")
  @@schema("academic")
}

model QuestionSet {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String     @db.VarChar(255)
  teacherId String     @map("teacher_id") @db.Uuid
  questions Question[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@index([teacherId])
  @@map("question_sets")
  @@schema("academic")
}

// =============================================================================
// ACADEMIC SCHEMA — Badges & Achievements (P14 W3-1)
// Sistem badge untuk penghargaan prestasi siswa.
// Criteria is JSONB: { type: 'grade_threshold', threshold: 90, subject: 'all' }
// Auto-award via event listeners (grade.submitted, attendance.recorded).
// =============================================================================

enum BadgeTier {
  bronze
  silver
  gold
  platinum

  @@schema("academic")
}

model Badge {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @unique @db.VarChar(100)
  name        String    @db.VarChar(255)
  description String?   @db.Text
  icon        String    @db.VarChar(50)  // emoji or SVG name
  criteria    Json      @db.JsonB
  tier        BadgeTier @default(bronze)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  studentBadges StudentBadge[]

  @@index([isActive])
  @@index([tier])
  @@map("badges")
  @@schema("academic")
}

model StudentBadge {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  badgeId   String   @map("badge_id") @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  awardedBy String?  @map("awarded_by") @db.Uuid  // auth.users.id (audit, no FK)
  awardedAt DateTime @default(now()) @map("awarded_at")

  badge   Badge   @relation(fields: [badgeId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([badgeId, studentId])
  @@index([studentId])
  @@map("student_badges")
  @@schema("academic")
}

// =============================================================================
// NOTIFICATION SCHEMA — WhatsApp Notification Log (P15 W3-4)
// Audit log for all WA notifications sent. Integrated with NotificationListener.
// =============================================================================

enum WaLogStatus {
  pending
  sent
  delivered
  read
  failed

  @@schema("notification")
}

model WaLog {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId         String?   @map("student_id") @db.Uuid    // audit ref (no FK)
  parentId          String?   @map("parent_id") @db.Uuid     // audit ref (no FK)
  recipient         String    @db.VarChar(100)               // phone number
  message           String    @db.Text
  status            WaLogStatus @default(pending)
  eventType         String?   @map("event_type") @db.VarChar(50)  // alpha, sakit, rpp_reviewed, etc.
  notificationLogId String?   @map("notification_log_id") @db.Uuid  // ref to notification.notification_logs (no FK)
  sentAt            DateTime? @map("sent_at")
  deliveredAt       DateTime? @map("delivered_at")
  readAt            DateTime? @map("read_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([studentId, createdAt])
  @@index([parentId, createdAt])
  @@index([eventType, createdAt])
  @@index([status, createdAt])
  @@map("wa_logs")
  @@schema("notification")
}

// =============================================================================
// GAMIFICATION SCHEMA — XP, Levels, Streaks (P15 W3-3)
// Sistem XP dan level untuk siswa. XP dari: modul completed, assessment
// submitted, attendance perfect. Level threshold determines rewards.
// =============================================================================

model StudentXp {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId  String   @unique @map("student_id") @db.Uuid
  totalXp    Int      @default(0) @map("total_xp")
  level      Int      @default(1)
  streakDays Int      @default(0) @map("streak_days")
  updatedAt  DateTime @updatedAt @map("updated_at")

  student      Student        @relation(fields: [studentId], references: [id])
  transactions XpTransaction[]

  @@map("student_xp")
  @@schema("gamification")
}

model XpTransaction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentXpId String   @map("student_xp_id") @db.Uuid
  amount      Int
  reason      String   @db.VarChar(255)
  source      String   @db.VarChar(50)  // 'lms_progress', 'grade_submitted', 'attendance', 'manual'
  createdAt   DateTime @default(now()) @map("created_at")

  studentXp StudentXp @relation(fields: [studentXpId], references: [id], onDelete: Cascade)

  @@index([studentXpId, createdAt])
  @@map("xp_transactions")
  @@schema("gamification")
}

// =============================================================================
// AI KNOWLEDGE SCHEMA — AI Generation Audit Trail (P16 W3-5)
// Audit trail for AI-powered content generation (questions, material, ATP).
// =============================================================================

model AiGeneration {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId  String   @map("teacher_id") @db.Uuid  // audit ref (no FK)
  type       String   @db.VarChar(50)  // 'questions', 'material', 'atp'
  prompt     String   @db.Text
  output     String   @db.Text
  model      String   @db.VarChar(100)
  tokensUsed Int?    @map("tokens_used")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([teacherId, createdAt])
  @@index([type, createdAt])
  @@map("ai_generations")
  @@schema("ai_knowledge")
}

// =============================================================================
// NOTIFICATION SCHEMA — Push Subscription (P16 W3-6)
// PWA push notification subscriptions for web push API.
// =============================================================================

model PushSubscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @db.Text
  keys      Json     @db.JsonB  // { p256dh: string, auth: string }
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
  @@schema("notification")
}
