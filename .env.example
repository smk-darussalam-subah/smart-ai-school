# =============================================================================
# ENVIRONMENT VARIABLES — Smart AI School (SMK Darussalam Subah)
# INSTRUKSI: Copy file ini ke .env dan isi semua nilai yang diperlukan
# JANGAN COMMIT file .env ke Git!
# =============================================================================

# ── NODE ENVIRONMENT ─────────────────────────────────────────────────────────
NODE_ENV=production
TZ=Asia/Jakarta

# ── POSTGRESQL DATABASE ──────────────────────────────────────────────────────
POSTGRES_DB=smk_db
POSTGRES_USER=smk_admin
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_MIN_20_CHAR

# Prisma connection string (digunakan oleh apps/api)
DATABASE_URL=postgresql://smk_admin:GANTI_DENGAN_PASSWORD_KUAT_MIN_20_CHAR@postgres:5432/smk_db

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=GANTI_DENGAN_PASSWORD_REDIS_KUAT
REDIS_URL=redis://:GANTI_DENGAN_PASSWORD_REDIS_KUAT@redis:6379

# ── KEYCLOAK ──────────────────────────────────────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=GANTI_DENGAN_PASSWORD_KEYCLOAK_KUAT

# Client secrets (generate dari Keycloak admin console setelah setup)
KEYCLOAK_WEB_CLIENT_SECRET=GENERATE_DARI_KEYCLOAK_ADMIN
KEYCLOAK_API_CLIENT_SECRET=GENERATE_DARI_KEYCLOAK_ADMIN
KEYCLOAK_MOBILE_CLIENT_SECRET=GENERATE_DARI_KEYCLOAK_ADMIN

# ── N8N AUTOMATION ────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=GANTI_DENGAN_PASSWORD_N8N_KUAT
N8N_ENCRYPTION_KEY=GENERATE_32_CHAR_RANDOM_STRING

# ── MONITORING ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=GANTI_DENGAN_PASSWORD_GRAFANA_KUAT

# ── MINIO FILE STORAGE ────────────────────────────────────────────────────────
MINIO_ROOT_USER=smkadmin
MINIO_ROOT_PASSWORD=GANTI_DENGAN_PASSWORD_MINIO_KUAT

# ── CLOUDFLARE R2 (untuk backup & CDN) ───────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=ISI_ACCOUNT_ID_CLOUDFLARE
CLOUDFLARE_R2_ACCESS_KEY_ID=ISI_R2_ACCESS_KEY
CLOUDFLARE_R2_SECRET_ACCESS_KEY=ISI_R2_SECRET_KEY
CLOUDFLARE_R2_BUCKET_NAME=smk-darussalam-backup
CLOUDFLARE_R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com

# ── AI PREMIUM APIs ───────────────────────────────────────────────────────────
# Anthropic Claude API (untuk konten marketing & laporan kompleks)
ANTHROPIC_API_KEY=sk-ant-GANTI_DENGAN_API_KEY_ANTHROPIC

# OpenAI (opsional, backup)
OPENAI_API_KEY=sk-GANTI_JIKA_DIGUNAKAN

# ── WHATSAPP / NOTIFIKASI ─────────────────────────────────────────────────────
# Fonnte (untuk WhatsApp notification)
FONNTE_API_KEY=GANTI_DENGAN_FONNTE_API_KEY
FONNTE_SENDER_NUMBER=628XXXXXXXXXX

# Admin IT phone number (untuk notifikasi sistem)
ADMIN_PHONE_NUMBER=628XXXXXXXXXX

# ── EMAIL ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@smkdarussalamsubah.sch.id
SMTP_PASSWORD=GANTI_DENGAN_APP_PASSWORD_GMAIL
SMTP_FROM_NAME=SMK Darussalam Subah

# ── NEXT.JS (Frontend) ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=SMK Darussalam Subah
NEXT_PUBLIC_APP_URL=https://smkdarussalamsubah.sch.id
NEXT_PUBLIC_API_URL=https://api.smkdarussalamsubah.sch.id
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.smkdarussalamsubah.sch.id
NEXT_PUBLIC_KEYCLOAK_REALM=smk-ecosystem
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=smk-web

# ── SECURITY ──────────────────────────────────────────────────────────────────
JWT_SECRET=GENERATE_64_CHAR_RANDOM_STRING_UNTUK_JWT
SESSION_SECRET=GENERATE_64_CHAR_RANDOM_STRING_UNTUK_SESSION

# =============================================================================
# CARA GENERATE PASSWORD KUAT:
# Linux/Mac: openssl rand -base64 32
# Atau: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================
