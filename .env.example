# =============================================================================
# ENVIRONMENT VARIABLES — Smart AI School (SMK Darussalam Subah)
# INSTRUKSI: Copy file ini ke .env dan isi semua nilai yang diperlukan
# JANGAN COMMIT file .env ke Git!
# =============================================================================

# ── NODE ENVIRONMENT ─────────────────────────────────────────────────────────
NODE_ENV=production
TZ=Asia/Jakarta

# ── POSTGRESQL DATABASE ──────────────────────────────────────────────────────
POSTGRES_DB=smk_db
POSTGRES_USER=smk_admin
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_MIN_20_CHAR

# Prisma connection string (digunakan oleh apps/api)
DATABASE_URL=postgresql://smk_admin:GANTI_DENGAN_PASSWORD_KUAT_MIN_20_CHAR@postgres:5432/smk_db

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=GANTI_DENGAN_PASSWORD_REDIS_KUAT
REDIS_URL=redis://:GANTI_DENGAN_PASSWORD_REDIS_KUAT@redis:6379

# ── KEYCLOAK ──────────────────────────────────────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=GANTI_DENGAN_PASSWORD_KEYCLOAK_KUAT

# Realm dan URL internal Docker network (digunakan apps/api)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=diis
KEYCLOAK_ISSUER=http://keycloak:8080/realms/diis

# Client secrets (generate dari Keycloak admin console setelah setup)
# Panduan: docs/deployment/keycloak-setup.md — Bagian 4
KEYCLOAK_WEB_CLIENT_SECRET=GENERATE_DARI_KEYCLOAK_ADMIN
KEYCLOAK_API_CLIENT_SECRET=GENERATE_DARI_KEYCLOAK_ADMIN

# ── NEXT-AUTH (apps/web) ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Production: NEXTAUTH_URL di-set literal di docker-compose.yml (https://smkdarussalamsubah.sch.id)
# Local dev: override dengan NEXTAUTH_URL=http://localhost:3000 di apps/web/.env.local
NEXTAUTH_SECRET=GENERATE_32_CHAR_RANDOM_STRING_UNTUK_NEXTAUTH
# KEYCLOAK_WEB_CLIENT_SECRET dipakai di compose sebagai KEYCLOAK_CLIENT_SECRET container web
# Sama dengan nilai KEYCLOAK_CLIENT_SECRET di apps/web/.env.local untuk local dev
KEYCLOAK_WEB_CLIENT_SECRET=GENERATE_DARI_KEYCLOAK_ADMIN
# API_URL: URL backend internal — di-set literal di compose; override untuk local dev
# API_URL=http://localhost:3001
# Issuer untuk local dev (beda dengan KEYCLOAK_ISSUER yang pakai hostname Docker)
KEYCLOAK_ISSUER_LOCAL=http://localhost:8080/realms/diis

# ── N8N AUTOMATION ────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=GANTI_DENGAN_PASSWORD_N8N_KUAT
N8N_ENCRYPTION_KEY=GENERATE_32_CHAR_RANDOM_STRING

# ── MONITORING ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=GANTI_DENGAN_PASSWORD_GRAFANA_KUAT

# ── MINIO FILE STORAGE ────────────────────────────────────────────────────────
MINIO_ROOT_USER=smkadmin
MINIO_ROOT_PASSWORD=GANTI_DENGAN_PASSWORD_MINIO_KUAT

# ── CLOUDFLARE R2 (untuk backup & CDN) ───────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=ISI_ACCOUNT_ID_CLOUDFLARE
CLOUDFLARE_R2_ACCESS_KEY_ID=ISI_R2_ACCESS_KEY
CLOUDFLARE_R2_SECRET_ACCESS_KEY=ISI_R2_SECRET_KEY
CLOUDFLARE_R2_BUCKET_NAME=smk-darussalam-backup
CLOUDFLARE_R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com

# ── AI PREMIUM APIs ───────────────────────────────────────────────────────────
# Anthropic Claude API (untuk konten marketing & laporan kompleks)
ANTHROPIC_API_KEY=sk-ant-GANTI_DENGAN_API_KEY_ANTHROPIC

# OpenAI (opsional, backup)
OPENAI_API_KEY=sk-GANTI_JIKA_DIGUNAKAN

# ── WHATSAPP / NOTIFIKASI ─────────────────────────────────────────────────────
# Fonnte (untuk WhatsApp notification)
# FONNTE_API_KEY dan ADMIN_PHONE_NUMBER juga di-pass ke service n8n di docker-compose.yml
# dan digunakan oleh n8n workflows (infrastructure/n8n/workflows/) via $env.FONNTE_API_KEY
# dan $env.ADMIN_PHONE_NUMBER. Wajib diisi agar notifikasi health-check & backup berjalan.
FONNTE_API_KEY=GANTI_DENGAN_FONNTE_API_KEY
FONNTE_SENDER_NUMBER=628XXXXXXXXXX

# Admin IT phone number (untuk notifikasi sistem) — format: 628xxxxxxxxx (tanpa + atau 0 di depan)
ADMIN_PHONE_NUMBER=628XXXXXXXXXX

# ── PWA PUSH NOTIFICATIONS (VAPID) ────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
# Required only when push notifications are enabled. Without these keys,
# push subscription endpoints work but sending is disabled (fail-soft).
VAPID_PUBLIC_KEY=GENERATE_DENGAN_npx_web-push_generate-vapid-keys
VAPID_PRIVATE_KEY=GENERATE_DENGAN_npx_web-push_generate-vapid-keys
# Subject URL for VAPID (must be a valid URL or mailto:)
VAPID_SUBJECT=mailto:admin@smkdarussalamsubah.sch.id
# R-18: Frontend needs the public key at BUILD TIME (Next.js NEXT_PUBLIC_ vars are baked into the build).
# This must be the SAME value as VAPID_PUBLIC_KEY above. Without it, push.ts reads empty string
# and isPushSupported() returns false — push notifications silently disabled.
# Ensure this is set in the Docker build environment (docker-compose build args or CI secrets).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=GENERATE_DENGAN_npx_web-push_generate-vapid-keys

# ── EMAIL ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@smkdarussalamsubah.sch.id
SMTP_PASSWORD=GANTI_DENGAN_APP_PASSWORD_GMAIL
SMTP_FROM_NAME=SMK Darussalam Subah

# ── NEXT.JS (Frontend) ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=SMK Darussalam Subah
NEXT_PUBLIC_APP_URL=https://smkdarussalamsubah.sch.id
NEXT_PUBLIC_API_URL=https://api.smkdarussalamsubah.sch.id
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.smkdarussalamsubah.sch.id
NEXT_PUBLIC_KEYCLOAK_REALM=diis
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=diis-web

# ── METABASE EMBED (SMA-47) ───────────────────────────────────────────────────
# Opsional — tanpa 3 var ini, halaman /dashboard/executive tampilkan placeholder.
# Setup: docs/runbooks/metabase-dashboard-ks-setup.md
METABASE_SITE_URL=https://analytics.smkdarussalamsubah.sch.id
METABASE_SECRET_KEY=ISI_DARI_METABASE_ADMIN_EMBEDDING_SECRET_KEY
METABASE_DASHBOARD_ID=1

# ── SECURITY ──────────────────────────────────────────────────────────────────
JWT_SECRET=GENERATE_64_CHAR_RANDOM_STRING_UNTUK_JWT
SESSION_SECRET=GENERATE_64_CHAR_RANDOM_STRING_UNTUK_SESSION

# =============================================================================
# CARA GENERATE PASSWORD KUAT:
# Linux/Mac: openssl rand -base64 32
# Atau: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================
